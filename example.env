DEBUG=false # Boolean (default "false")

BOT_TOKEN= # String (with "" or without)
DATABASE_URL= # String (recommend with "" but possible without)
CLIENT_ID= # String - the bot's application/client ID
GUILD_ID= # String - the development guild ID (optional)
OWNER_ID= # String - the bot owner's Discord user ID
PREFIX=; # String - the message command prefix (default ";")
NODE_ENV=development # "development" or "production"

# Webhook logging URLs (leave empty to disable)
LOG_ERROR_WEBHOOK= # Discord webhook URL for error-level logs
LOG_INFO_WEBHOOK= # Discord webhook URL for info-level logs
LOG_DEBUG_WEBHOOK= # Discord webhook URL for debug-level logs
